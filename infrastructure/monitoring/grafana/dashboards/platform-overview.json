  "panels": [
    {
      "title": "Workflow Executions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(ant_workflow_total[5m])",
          "legendFormat": "total"
        },
        {
          "expr": "rate(ant_workflow_success[5m])",
          "legendFormat": "success"
        },
        {
          "expr": "rate(ant_workflow_failed[5m])",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "title": "Workflow Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ant_workflow_duration_ms_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "title": "Connector Calls",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(ant_connector_calls[5m])",
          "legendFormat": "{{ connector }}"
        }
      ]
    },
    {
      "title": "Connector Error Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(ant_connector_errors[5m])) / sum(rate(ant_connector_calls[5m]))",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "title": "Model Inference Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ant_model_latency_ms_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "title": "Approval Request Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ant_approval_latency_ms_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    }
  ],
