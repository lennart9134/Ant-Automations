# =============================================================================
# Ant Automations — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your deployment.
# Never commit .env to version control.
# =============================================================================

# --- Postgres -----------------------------------------------------------------
POSTGRES_USER=ant
POSTGRES_PASSWORD=ant
POSTGRES_DB=ant
POSTGRES_DSN=postgresql://ant:ant@postgres:5432/ant

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# --- NATS ---------------------------------------------------------------------
NATS_URL=nats://nats:4222

# --- MinIO (S3-compatible object storage) ------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000

# --- Control Plane ------------------------------------------------------------
# JWT secret for RBAC token verification (leave empty for dev-mode bypass)
JWT_SECRET=
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Observability ------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=ant-automations
# Grafana admin password
GF_SECURITY_ADMIN_PASSWORD=admin

# --- Vision Service -----------------------------------------------------------
# SGLang runtime endpoint (Phi-4-reasoning-vision-15B)
SGLANG_ENDPOINT=http://localhost:30000

# --- Planner Service ----------------------------------------------------------
# Model serving endpoint (Qwen3-30B-A3B via SGLang)
PLANNER_MODEL_ENDPOINT=http://localhost:30001

# --- Deployment ---------------------------------------------------------------
# Environment: development | staging | production
ENVIRONMENT=development
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Enable structured JSON logging (recommended for production)
LOG_FORMAT=json
