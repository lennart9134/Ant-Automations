{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ant Observation Agent",
  "version": "0.1.0",
  "identifier": "com.antautomations.observation-agent",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Ant Observation Agent",
        "width": 520,
        "height": 420,
        "visible": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'"
    },
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "Ant Observation — active"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null
    }
  }
}
