{
  "manifest_version": 3,
  "name": "Ant Observation Agent",
  "short_name": "Ant",
  "version": "0.1.0",
  "description": "Captures SaaS navigation + form-submission metadata for the Ant Automations Watch layer. Never captures form values, clipboard, or screen content.",

  "minimum_chrome_version": "116",

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "Ant Observation",
    "default_popup": "popup.html"
  },

  "permissions": [
    "activeTab",
    "webNavigation",
    "storage",
    "alarms"
  ],

  "host_permissions": [],

  "optional_host_permissions": [
    "https://*/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "storage": {
    "managed_schema": "managed_schema.json"
  }
}
